# findata-mcp environment variables
# Copy this file to .env and fill in the values that apply to your setup.
# .env is git-ignored — never commit it.

# Path to the Codex CLI binary.
# Default: /Applications/Codex.app/Contents/Resources/codex  (macOS)
# CODEX_CLI_PATH=/Applications/Codex.app/Contents/Resources/codex

# FRED API key — required only if you use get_fred_series().
# Obtain one free at https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your_key_here

# AlphaVantage API key — required for get_alphavantage_prices().
# Free tier (heavily rate-limited): https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=your_key_here

# Tiingo API key — required for get_tiingo_prices().
# Free tier covers daily EOD data: https://www.tiingo.com/account/api/token
# TIINGO_API_KEY=your_key_here

# Polygon.io API key — required for get_polygon_aggregates().
# Free tier (rate-limited): https://polygon.io/dashboard/api-keys
# POLYGON_API_KEY=your_key_here

# SEC EDGAR User-Agent — required for get_sec_edgar_filings().
# SEC requires a descriptive contact string on every request.
# Example: "Acme Research research@example.com"
# SEC_EDGAR_USER_AGENT=Your Name your_email@example.com

# WRDS credentials — required for get_wrds_data() if not using ~/.pgpass.
# Free for university affiliates: https://wrds-www.wharton.upenn.edu/
# WRDS_USERNAME=your_username
# WRDS_PASSWORD=your_password
